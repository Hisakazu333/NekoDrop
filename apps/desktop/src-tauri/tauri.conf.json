{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NekoDrop",
  "version": "0.1.0",
  "identifier": "app.nekodrop.desktop",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data:; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'none'; frame-ancestors 'none'"
    },
    "windows": [
      {
        "title": "NekoDrop",
        "width": 1180,
        "height": 760,
        "minWidth": 940,
        "minHeight": 620,
        "center": true,
        "resizable": true,
        "dragDropEnabled": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
